# Database
DATABASE_URL=postgresql://musicapp:musicapp123@localhost:5432/musicdb
DATABASE_URL_TEST=postgresql://musicapp:musicapp123@localhost:5432/musicdb_test

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS
ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:5173", "http://localhost:8001", "http://localhost:5174"]

# S3 Storage
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=music-marketplace-images
AWS_S3_REGION=us-east-1
AWS_S3_CUSTOM_DOMAIN=
